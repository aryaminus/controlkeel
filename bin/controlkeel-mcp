#!/usr/bin/env sh
set -eu

export CK_MCP_MODE="${CK_MCP_MODE:-1}"
# Suppress Mix compile / task chatter on stdout before ck.mcp runs (stdio JSON-RPC).
export MIX_QUIET="${MIX_QUIET:-1}"
export MIX_ENV="${MIX_ENV:-dev}"

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
APP_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
# Cursor passes CK_PROJECT_ROOT in MCP env; cwd may not be the governed workspace.
PROJECT_ROOT="${CK_PROJECT_ROOT:-$(/bin/pwd -P)}"

# Optional: force a specific `controlkeel` executable (must support `mcp`, e.g. Burrito
# build or a wrapper). Do **not** point at `_build/.../rel/.../bin/controlkeel` from
# `mix release` alone — that script only knows start/eval/remote/etc., not `mcp`.
if [ -n "${CONTROLKEEL_BIN:-}" ]; then
  exec "$CONTROLKEEL_BIN" mcp --project-root "$PROJECT_ROOT" "$@"
fi

# ControlKeel *source* tree (this Git repo): always `mix ck.mcp` so MCP matches
# your checkout. A plain `mix release` artifact does not register a `mcp` CLI on
# bin/controlkeel. Do not use a global `controlkeel` on PATH here — that is often
# an older Homebrew build and does not match uncommitted work.
if [ -f "$APP_ROOT/mix.exs" ] && [ -f "$APP_ROOT/lib/controlkeel/application.ex" ]; then
  cd "$APP_ROOT"
  exec mix ck.mcp --project-root "$PROJECT_ROOT" "$@"
fi

# Governed / other projects: optional global binary, then mix from this tree.
if command -v controlkeel >/dev/null 2>&1; then
  exec controlkeel mcp --project-root "$PROJECT_ROOT" "$@"
fi

cd "$APP_ROOT"
exec mix ck.mcp --project-root "$PROJECT_ROOT" "$@"
