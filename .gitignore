# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/
/.tmp/

# Ignore package tarball (built via "mix hex.build").
controlkeel-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/
/burrito_out/

# Database files
*.db
*.db-*

/controlkeel/*
!/controlkeel/bin/
/controlkeel/bin/*
!/controlkeel/bin/controlkeel-mcp

# Local Cursor / agent session exports (large; not part of the app)
session-ses_*.md

# Local companion artifacts generated by CK attach commands
/.agents/
/.codex/
/.claude/
/.factory/
/.hermes/
/.openclaw/
/.forge/
/.cursor/
/.cursor-plugin/*
!/.cursor-plugin/plugin.json
/.windsurf/
/.continue/
/.cline/
/.clinerules/
/.roo/
/.roomodes
/.goosehints
/goose/
/.opencode/
/.gemini/
/.kiro/
/.kilo/
/.amp/
/.augment/
/.aider/
/.aider.conf.yml
/.mcp.json
/.mcp.hosted.json
/gemini-extension.json
/pi-extension.json
/GEMINI.md
/AUGMENT.md
/CLAUDE.md
/AIDER.md
/PI.md
/copilot-instructions.md
/plugins/
/README.gemini-controlkeel.md
/skills/
/packages/npm/controlkeel/vendor/
/.vscode/extensions.json
/.vscode/mcp.json
/.github/agents/
/.github/skills/
/.github/commands/
/.github/mcp.json
/.github/copilot-instructions.md
