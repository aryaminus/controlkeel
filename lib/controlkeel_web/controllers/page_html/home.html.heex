<Layouts.flash_group flash={@flash} />
<section class="ck-shell">
  <div class="ck-grid">
    <div class="ck-hero-panel">
      <p class="ck-kicker">Control tower for agent-built software</p>
      <h1 class="ck-display">Turn agent-generated work into production-ready delivery.</h1>
      <p class="ck-lead">
        ControlKeel is the control tower that turns agent-generated work into secure, scoped, validated,
        production-ready delivery. It sits above Claude Code, Codex, Cursor, Replit, and other agents to
        compile intent, constrain risk, generate manageable tasks, and keep proof attached to every mission.
      </p>
      <div class="ck-action-row">
        <a href={~p"/start"} class="ck-button-primary">Start a mission</a>
        <div class="ck-inline-stats">
          <span>Intent</span>
          <span>Policy</span>
          <span>Proof</span>
        </div>
      </div>
    </div>

    <div class="ck-side-stack">
      <div class="ck-card ck-card-contrast">
        <p class="ck-mini-label">Proof console loop</p>
        <ul class="ck-mini-list">
          <li>Mission Control for live task state, approvals, and blocked work</li>
          <li>Proof Browser for immutable audit artifacts and rollback guidance</li>
          <li>Ship metrics and benchmarks for outcome evidence</li>
        </ul>
      </div>
      <div class="ck-card">
        <p class="ck-mini-label">Who it is for</p>
        <p class="ck-note">
          Serious solo builders and tiny agent-heavy teams who already generate code but still need scoped delivery, approvals, and proof.
        </p>
      </div>
      <div class="ck-card">
        <p class="ck-mini-label">Occupation-first onboarding</p>
        <p class="ck-note">
          Users choose what best describes their work. ControlKeel maps that to the right domain pack, interview language, and governance posture without forcing framework acronyms first.
        </p>
      </div>
      <div class="ck-card">
        <p class="ck-mini-label">What it is not</p>
        <ul class="ck-mini-list">
          <li>Not another IDE or coding model</li>
          <li>Not a prompt marketplace</li>
          <li>Not post-hoc code review only</li>
        </ul>
      </div>
      <div class="ck-card">
        <p class="ck-mini-label">Governed autonomy</p>
        <p class="ck-note">
          Findings, approvals, and budget limits stay visible in plain language so non-experts can understand risk without giving the agent full autopilot.
        </p>
      </div>
      <div class="ck-card">
        <p class="ck-mini-label">Ship metrics</p>
        <p class="ck-note">
          Proof-backed done tasks: {if @ship_summary.outcome_metrics.proof_backed_task_coverage_percent,
            do: "#{@ship_summary.outcome_metrics.proof_backed_task_coverage_percent}%",
            else: "not recorded"}.
          Deploy-ready task rate: {if @ship_summary.outcome_metrics.deploy_ready_task_rate_percent,
            do: "#{@ship_summary.outcome_metrics.deploy_ready_task_rate_percent}%",
            else: "not recorded"}.
        </p>
        <a href={~p"/ship"} class="ck-link">Open ship dashboard</a>
      </div>
      <div class="ck-card">
        <p class="ck-mini-label">Benchmark matrix</p>
        <p class="ck-note">
          {@benchmark_summary.total_runs} persisted benchmark runs across {@benchmark_summary.total_suites} suites.
          Average catch rate: {if @benchmark_summary.average_catch_rate,
            do: "#{Float.round(@benchmark_summary.average_catch_rate, 1)}%",
            else: "not recorded"}.
        </p>
        <a href={~p"/benchmarks"} class="ck-link">Open benchmarks</a>
      </div>
      <div class="ck-card">
        <p class="ck-mini-label">Install guide</p>
        <p class="ck-note">
          Follow the 5-minute path from first launch to first governed finding, with the exact commands used by the packaged binary and source setup.
        </p>
        <a href={~p"/getting-started"} class="ck-link">Open getting-started guide</a>
      </div>
      <div class="ck-card">
        <p class="ck-mini-label">Skills + integrations</p>
        <p class="ck-note">
          Export native skills and plugin bundles for Claude Code, Codex, and Copilot / VS Code, or use MCP plus generated instruction packs for Cursor, Windsurf, Continue, Aider, and other clients.
        </p>
        <a href={~p"/skills"} class="ck-link">Open skills studio</a>
      </div>
    </div>
  </div>

  <div class="ck-section-header">
    <div>
      <p class="ck-kicker">Recent missions</p>
      <h2 class="ck-section-title">Latest control-tower runs</h2>
    </div>
    <div class="ck-action-row">
      <a href={~p"/benchmarks"} class="ck-link">View benchmark matrix</a>
      <a href={~p"/ship"} class="ck-link">View ship metrics</a>
      <a href={~p"/skills"} class="ck-link">View skills studio</a>
      <a href={~p"/start"} class="ck-link">Launch a new mission</a>
    </div>
  </div>

  <div class="ck-session-grid">
    <%= if @recent_sessions == [] do %>
      <div class="ck-card ck-empty-state">
        <p class="ck-empty-title">No missions yet.</p>
        <p class="ck-note">
          Create the first one and ControlKeel will generate the brief, tasks, and findings.
        </p>
      </div>
    <% else %>
      <%= for session <- @recent_sessions do %>
        <a href={~p"/missions/#{session.id}"} class="ck-card ck-session-card">
          <div class="ck-session-head">
            <div>
              <p class="ck-mini-label">{session.workspace.industry |> String.capitalize()}</p>
              <h3>{session.title}</h3>
            </div>
            <span class={["ck-pill", "ck-pill-#{session.risk_tier}"]}>{session.risk_tier}</span>
          </div>
          <p class="ck-note">{session.objective}</p>
          <div class="ck-metric-row">
            <span>{Enum.count(session.findings)} findings</span>
            <span>{Enum.count(session.tasks)} tasks</span>
            <span>${session.budget_cents |> Kernel./(100) |> trunc()}/mo cap</span>
          </div>
        </a>
      <% end %>
    <% end %>
  </div>
</section>
