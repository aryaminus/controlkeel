[
  {
    "id": "secret.aws_access_key",
    "category": "security",
    "severity": "critical",
    "action": "block",
    "plain_message": "We found what looks like a hardcoded AWS access key. Move it into an environment variable or secret manager before continuing.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "AKIA[0-9A-Z]{16}"
      ]
    }
  },
  {
    "id": "secret.hardcoded_credential",
    "category": "security",
    "severity": "high",
    "action": "block",
    "plain_message": "This looks like a hardcoded credential. Keep credentials out of source and pass them in through environment variables or a secrets manager.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "(?i)(api[_-]?key|secret[_-]?key|secret|token|password|master[_-]?password|database[_-]?url)\\s*[:=]\\s*[\"'][^\"'\\n]{6,}[\"']",
        "(?i)@(api_key|secret_key|master_password|admin_password|auth_token|access_token|private_key)\\s+[\"'][^\"'\\n]{6,}[\"']"
      ]
    }
  },
  {
    "id": "secret.high_entropy_token",
    "category": "security",
    "severity": "high",
    "action": "block",
    "plain_message": "We found a secret-like token in plain text. Replace it with a reference to a secure secret store before execution continues.",
    "matcher": {
      "type": "entropy",
      "candidate_pattern": "[A-Za-z0-9_\\-=/+]{20,}",
      "min_length": 20,
      "threshold": 3.5
    }
  },
  {
    "id": "security.sql_injection",
    "category": "security",
    "severity": "critical",
    "action": "block",
    "plain_message": "This content looks like SQL built directly from user input. Switch to parameterized queries before the agent keeps going.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "(?i)(['\"])\\s*or\\s*1=1",
        "(?i)union\\s+select",
        "(?i)drop\\s+table",
        "(?i)select\\s+.+\\s+from\\s+.+(\\+|#\\{|\\$\\{|<>|\\|\\|)"
      ]
    }
  },
  {
    "id": "security.xss_unsafe_html",
    "category": "security",
    "severity": "high",
    "action": "block",
    "plain_message": "This content writes raw HTML into the page. Prefer safer rendering paths before shipping it.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "(?i)<script\\b",
        "(?i)innerHTML\\s*=",
        "(?i)dangerouslySetInnerHTML"
      ]
    }
  },
  {
    "id": "security.open_redirect",
    "category": "security",
    "severity": "high",
    "action": "block",
    "plain_message": "Redirect destination is controlled by user input. An attacker can redirect users to a malicious site. Validate the redirect target against an allowlist.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "(?i)(redirect|location\\s*[=:]).{0,80}(params\\[|request\\.(args|form|query|body)|req\\.(query|body|params)|conn\\.params)",
        "(?i)redirect\\(conn,\\s*(to:|external:)\\s*(params|conn\\.params)"
      ]
    }
  },
  {
    "id": "security.unsafe_deserialization",
    "category": "security",
    "severity": "critical",
    "action": "block",
    "plain_message": "Deserializing untrusted data can lead to remote code execution. Use a safe format like JSON and never pass user-controlled input to pickle, Marshal, or unserialize.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "(?i)pickle\\.loads\\s*\\(",
        "(?i)marshal\\.load\\s*\\(",
        "(?i)yaml\\.load\\s*\\((?!.*Loader\\s*=\\s*yaml\\.SafeLoader)",
        "(?i)\\bunserialize\\s*\\(",
        "(?i)Marshal\\.load\\s*\\("
      ]
    }
  },
  {
    "id": "security.jwt_none_algorithm",
    "category": "security",
    "severity": "critical",
    "action": "block",
    "plain_message": "JWT 'none' algorithm disables signature verification and allows token forgery. Always enforce a specific signing algorithm and reject tokens that specify 'none'.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "(?i)[\"']alg[\"']\\s*(?:[:,]|=>)\\s*[\"']none[\"']",
        "(?i)(algorithm|alg)\\s*(?:[=:]|=>)\\s*[\"']none[\"']",
        "(?i)algorithms\\s*=\\s*\\[.*[\"']none[\"']"
      ]
    }
  },
  {
    "id": "security.plaintext_password_storage",
    "category": "security",
    "severity": "critical",
    "action": "block",
    "plain_message": "Passwords must be hashed with a strong KDF (bcrypt, argon2, pbkdf2) before storage. Never store or persist plaintext passwords.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "(?i)field\\s*\\(?\\s*:(password|password_hash|passwd)\\s*,\\s*:string",
        "(?i)(user\\.password|account\\.password)\\s*=\\s*(?!.*hash|.*bcrypt|.*argon|.*scrypt|.*pbkdf)"
      ]
    }
  },
  {
    "id": "security.file_upload_no_validation",
    "category": "security",
    "severity": "high",
    "action": "warn",
    "plain_message": "File uploads must validate content type and file extension before writing to disk. Unrestricted uploads can lead to stored XSS or code execution.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "(?i)(File\\.cp!|File\\.write!|shutil\\.copy|move_uploaded_file).{0,100}(upload|tmp_path|filename)",
        "(?i)\\bPlug\\.Upload\\b"
      ]
    }
  },
  {
    "id": "security.env_dump_leak",
    "category": "security",
    "severity": "high",
    "action": "block",
    "plain_message": "Dumping all environment variables exposes every secret to logs or responses. Access only the specific variables your code needs.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "System\\.get_env\\(\\)",
        "(?i)(os\\.environ\\.copy\\(\\)|os\\.environ\\.items\\(\\)|ENV\\.to_h\\b)"
      ]
    }
  },
  {
    "id": "security.mass_assignment",
    "category": "security",
    "severity": "critical",
    "action": "block",
    "plain_message": "Protected fields such as user_id, role, status, discounts, or refunds must not be mass-assigned from user params. Set them explicitly from trusted server context.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "(?is)cast\\s*\\([^\\)]*,\\s*\\[[^\\]]*:(?:user_id|role|admin|is_admin|status|discount_percent|refunded_amount)[^\\]]*\\]",
        "(?is)permit\\s*\\([^\\)]*(?:user_id|role|admin|is_admin|status|discount_percent|refunded_amount)"
      ]
    }
  }
]
