[
  {
    "id": "ecommerce.payment_logging",
    "category": "security",
    "severity": "critical",
    "action": "block",
    "plain_message": "E-commerce flows must never log full card numbers, CVV values, or raw checkout tokens.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "(?i)(log|logger\\.|console\\.log|IO\\.inspect).*(card_number|cvv|cvc|checkout_token|payment_token)",
        "(?i)(pan|card number|cvv|cvc)"
      ]
    }
  },
  {
    "id": "ecommerce.refund_guardrail_bypass",
    "category": "fraud",
    "severity": "high",
    "action": "warn",
    "plain_message": "Automated refund or chargeback handling should preserve review thresholds, abuse controls, and audit trails.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "(?i)(auto_refund|issue_refund|chargeback).*(without_review|skip_review|always_true)",
        "(?i)(disable|bypass).*(fraud|refund review|chargeback review)"
      ]
    }
  },
  {
    "id": "ecommerce.idor_order_lookup",
    "category": "security",
    "severity": "critical",
    "action": "block",
    "plain_message": "Order lookups by URL id must be scoped to the authenticated user or authorization context before returning customer, shipping, or payment data.",
    "matcher": {
      "type": "regex",
      "patterns": [
        "(?is)Repo\\.get!\\s*\\(\\s*(?:Order|__MODULE__)\\s*,\\s*id\\s*\\).*json\\s*\\([^\\)]*(?:shipping_address|payment_|user_id|items)",
        "(?is)def\\s+show\\s*\\([^\\n]*%\\{[\\\"']id[\\\"']\\s*=>\\s*id\\}.*Repo\\.get!\\s*\\(\\s*Order\\s*,\\s*id\\s*\\)"
      ]
    }
  }
]
